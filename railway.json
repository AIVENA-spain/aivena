{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
      "buildCommand": "npx tsc --project apps/api/tsconfig.json"
    },
    "deploy": {
      "startCommand": "node dist/apps/api/src/index.js",
      "healthcheckPath": "/health",
      "restartPolicyType": "ON_FAILURE"
    }
  }